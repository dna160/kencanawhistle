# ─────────────────────────────────────────────────────────────────────────────
# Whistleblow — Environment Variables
# Copy to .env.local for local development. NEVER commit .env.local.
# All secrets must live in environment/secret storage, never in the repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Injected automatically by Railway on private network. Format:
#   postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL=

# ── Application ──────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.up.railway.app
NODE_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────────
# 32+ random bytes, base64-encoded. Generate: openssl rand -base64 32
AUTH_SECRET=

# TOTP issuer name shown in authenticator apps (e.g. "Google Authenticator")
TOTP_ISSUER=Whistleblow

# ── Field-level encryption (RECOMMENDED — see PRD §8) ────────────────────────
# AES-256-GCM key. Generate: openssl rand -base64 32
# Leave empty to disable field encryption (not recommended for production).
ENCRYPTION_KEY=

# ── Email notifications (content-free reviewer alerts) ────────────────────────
# SMTP credentials for sending notification emails to reviewers.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── Governance ───────────────────────────────────────────────────────────────
# [DECIDE] UU PDP No. 27/2022 retention — confirm with Indonesian counsel.
# Days after a report is closed before its data is scheduled for purge.
RETENTION_DAYS=1095

# Email of the external escalation party (independent auditor / counsel).
# Activated when the entire Board is recused from a case.
EXTERNAL_ESCALATION_EMAIL=

# Minimum number of non-conflicted commissioners before auto-escalating.
# If active commissioners minus recused < RECUSAL_QUORUM, case escalates.
RECUSAL_QUORUM=2

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max report submissions per IP per hour (applies to non-anonymous path only
# because anonymous path does not log IP).
RATE_LIMIT_SUBMISSIONS_PER_HOUR=10
# Max access-code attempts per IP per 15 minutes
RATE_LIMIT_CODE_ATTEMPTS_PER_15MIN=5
